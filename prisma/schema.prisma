// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum NoteType {
  TOP_NOTE
  HEART_NOTE
  BASE_NOTE
}

model User {
  id                      String        @id @default(auto()) @map("_id") @db.ObjectId
  fullname                String?
  name                    String? // Legacy / alternate name reference
  email                   String        @unique
  password                String
  image                   String? // Profile picture or avatar
  phoneNumber             String?
  isVerify                Boolean       @default(false)
  verificationCode        Int?
  verificationCodeExpires DateTime?
  role                    String        @default("user") // superadmin, admin, user
  gender                  String? // Male, Female
  address                 String?
  city                    String?
  postalCode              String?
  status                  String        @default("isProgress") // isProgress, active, blocked
  isDelete                Boolean       @default(false)
  passwordChangedAt       DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  orders      Order[]
  savedBlends CustomBlend[]
  reviews     Review[]
}

model Collection {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  numberOfProducts Int         @default(0)
  image            String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

type ProductImage {
  image    String
  position Int
}

type ProductFaq {
  question  String
  answer    String
  isvisible Boolean @default(true)
}

type SectionTwoCard {
  image       String
  slogan      String
  title       String
  description String
}

type SectionTwo {
  show        Boolean
  title       String
  description String
  cards       SectionTwoCard[]
}

model Product {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  label           String
  name            String
  category        String         // ObjectId reference to Collection
  price           Float
  images          ProductImage[]  // e.g. [{image: "url", position: 0}, {image: "url", position: 1}, ...]
  sizes           String[]       // e.g. ["30ml", "50ml", "100ml"]
  tags            String[]       // e.g. ["luxury", "floral", "oud"]
  reviews         Review[]
  description     String?
  isAvailable     Boolean        @default(true)
  stock           Int?           // numeric stock quantity
  orderItems      OrderItem[]
  faqs            ProductFaq[]
  sectiontwo      SectionTwo?
  hasfreedelivery Boolean        @default(false)
  isfeatured      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Review { // users can only review a product if they have purchased it
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  productId   String   @db.ObjectId
  product     Product  @relation(fields: [productId], references: [id])
  rating      Int
  comment     String
  pictures    String[]
  createdAt   DateTime @default(now())
}

model Ingredient {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  category    String // An Oriental Wood, Floral Elixir, etc.
  type        NoteType
  description String
  image       String
  stock       Int               @default(1000) // ml
  blends      BlendIngredient[]
}

model CustomBlend {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String?  @db.ObjectId
  user          User?    @relation(fields: [userId], references: [id])
  name          String   // Name printed on the physical label
  
  // Dynamic pricing components saved at the time of blend generation
  price         Float    @default(70.00)
  bottleSize    String   @default("100ml") // e.g. "30ml", "50ml", "100ml"
  concentration String   @default("20%")   // e.g. "20%", "30%", "40%"
  mediumId      String?  @db.ObjectId      // Reference to the essence medium
  medium        EssenceMedium? @relation(fields: [mediumId], references: [id])
  // Custom physical label styling parameters
  labelBg       String   @default("#F2CA50") // Hex code
  textColor     String   @default("#000000") // Hex code
  textAlign     String   @default("center")
  labelFontSize Float    @default(1.0)
  productType   String   @default("Fragrance") // Can represent medium or custom label header
  createdAt     DateTime @default(now())
  ingredients   BlendIngredient[]
  orderItems    OrderItem[]
}

model EssenceMedium {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String   @unique // e.g., "F", "E", "A", "S"
  name        String   // e.g., "Fragrance", "Essence Oil", "Artisanal Soap", "Shower Gel"
  description String   // Descriptive subtext (e.g. "Alcohol-free botanical oil blend")
  icon        String?  // SVG path or character representation
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  blends      CustomBlend[]
}

model SizePricing {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  size        String   @unique // e.g., "30ml", "50ml", "100ml"
  label       String   // e.g., "30mL", "50mL", "100mL"
  price       Float    // Base price (e.g., 25.00, 45.00, 70.00)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ConcentrationLevel {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  percentage      String   @unique // e.g. "20%", "30%", "40%"
  name            String   // e.g. "EDP", "Extrait", "Parfum"
  additionalPrice Float    // Pricing add-on (e.g. 0.00, 10.00, 20.00)
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CuratedProduct {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String   // e.g., "Royal Oud Intense"
  category      String   // e.g., "Private Reserve", "Les Ephemeres", "L'Heritage"
  image         String   // Path to asset (e.g. "/product (1).png")
  description   String   // Poetic fragrance description
  
  // Stored static recipe parameters for admin designs
  formulaIds    String[] // Array of Ingredient database ObjectIds
  percentages   Json     // Map of Ingredient ID strings to percentages: { "60ba7c2d...": 50 }
  
  bottleSize    String   @default("100ml")
  concentration String   @default("30%")
  labelBg       String   @default("#1A1C1C")
  textColor     String   @default("#F2CA50")
  textAlign     String   @default("center")
  labelFontSize Float    @default(1.0)
  
  isFeatured    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BlendIngredient {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  blendId      String      @db.ObjectId
  blend        CustomBlend @relation(fields: [blendId], references: [id])
  ingredientId String      @db.ObjectId
  ingredient   Ingredient  @relation(fields: [ingredientId], references: [id])
  percentage   Int // 0-100
}

model Order {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  userId          String      @db.ObjectId
  user            User        @relation(fields: [userId], references: [id])
  totalAmount     Float
  status          OrderStatus @default(PENDING)
  shippingAddress String
  paymentId       String? // Stripe/PayPal reference
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items OrderItem[]
}

model OrderItem {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  orderId String @db.ObjectId
  order   Order  @relation(fields: [orderId], references: [id])

  // An item can be a standard product OR a custom blend
  productId String?  @db.ObjectId
  product   Product? @relation(fields: [productId], references: [id])

  customBlendId String?      @db.ObjectId
  customBlend   CustomBlend? @relation(fields: [customBlendId], references: [id])

  quantity Int   @default(1)
  price    Float // Price at time of purchase
}

model Setting {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  aboutus         String?
  aboutusimage    String?
  adminmessage    String?
  adminimage      String?
  privacyPolicy   String?
  termsConditions String?

  // Brand Logo Information
  navbarLogo      String?
  footerLogo      String?

  // Socials and Contact Information
  facebook        SiteConfigField?
  instagram       SiteConfigField?
  twitter         SiteConfigField?
  linkedin        SiteConfigField?
  youtube         SiteConfigField?
  tiktok          SiteConfigField?
  whatsapp        SiteConfigField?
  telegram        SiteConfigField?
  snapchat        SiteConfigField?
  address         SiteConfigField?
  phone           SiteConfigField?
  email           SiteConfigField?
  website         SiteConfigField?
  appName         SiteConfigField?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

type SiteConfigField {
  url      String?
  isActive Boolean @default(true)
}

model Faq {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  question     String
  answer       String
  questionType String   @default("general") // general, valuation, product, etc.
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Inquiry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String
  inquiryType String   // general, order, commission, discovery
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
