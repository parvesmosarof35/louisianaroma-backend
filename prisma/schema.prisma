// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum NoteType {
  TOP_NOTE
  HEART_NOTE
  BASE_NOTE
}

model User {
  id                      String        @id @default(auto()) @map("_id") @db.ObjectId
  fullname                String?
  name                    String? // Legacy / alternate name reference
  email                   String        @unique
  password                String
  image                   String? // Profile picture or avatar
  phoneNumber             String?
  isVerify                Boolean       @default(false)
  verificationCode        Int?
  verificationCodeExpires DateTime?
  role                    String        @default("user") // superadmin, admin, user, driver, etc.
  gender                  String? // Male, Female
  address                 String?
  status                  String        @default("isProgress") // isProgress, active, blocked
  isDelete                Boolean       @default(false)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  orders      Order[]
  savedBlends CustomBlend[]
}

model Product {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  category    String // Private Reserve, Les Ephemeres, etc.
  notes       String // Comma separated notes description
  price       Float
  image       String
  description String?
  isAvailable Boolean     @default(true)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
}

model Ingredient {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  category    String // An Oriental Wood, Floral Elixir, etc.
  type        NoteType
  description String
  image       String
  stock       Int               @default(1000) // ml
  blends      BlendIngredient[]
}

model CustomBlend {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String?  @db.ObjectId
  user          User?    @relation(fields: [userId], references: [id])
  name          String // Fragrance Name from Labeling step
  price         Float    @default(450.00)
  labelBg       String // Hex color
  textColor     String // Hex color
  textAlign     String   @default("center")
  labelFontSize Float    @default(1.0)
  productType   String   @default("Fragrance")
  createdAt     DateTime @default(now())

  ingredients BlendIngredient[]
  orderItems  OrderItem[]
}

model BlendIngredient {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  blendId      String      @db.ObjectId
  blend        CustomBlend @relation(fields: [blendId], references: [id])
  ingredientId String      @db.ObjectId
  ingredient   Ingredient  @relation(fields: [ingredientId], references: [id])
  percentage   Int // 0-100
}

model Order {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  userId          String      @db.ObjectId
  user            User        @relation(fields: [userId], references: [id])
  totalAmount     Float
  status          OrderStatus @default(PENDING)
  shippingAddress String
  paymentId       String? // Stripe/PayPal reference
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items OrderItem[]
}

model OrderItem {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  orderId String @db.ObjectId
  order   Order  @relation(fields: [orderId], references: [id])

  // An item can be a standard product OR a custom blend
  productId String?  @db.ObjectId
  product   Product? @relation(fields: [productId], references: [id])

  customBlendId String?      @db.ObjectId
  customBlend   CustomBlend? @relation(fields: [customBlendId], references: [id])

  quantity Int   @default(1)
  price    Float // Price at time of purchase
}

model Setting {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  aboutUs         String?
  privacyPolicy   String?
  termsConditions String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Faq {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  question     String
  answer       String
  questionType String   @default("general") // general, valuation, product, etc.
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
